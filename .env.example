# Copia este archivo a .env en la raíz del proyecto para docker compose.
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# Seguridad (cambia en producción)
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=1d

# Google Gemini (opcional; necesario para generación con IA)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_RETRY_MAX=3
GEMINI_RETRY_BASE_MS=1500

# URL del API que usará el navegador al abrir el frontend
VITE_API_URL=http://localhost:3000/api

# Origen permitido por CORS del backend (URL del frontend en el navegador)
CORS_ORIGIN=http://localhost:8080

# Ejecutar seed demo al arrancar el backend (true/false)
RUN_SEED=true
